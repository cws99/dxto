Prefix(:=<http://purl.obolibrary.org/obo/dxto.owl#>)
Prefix(dce:=<http://purl.org/dc/elements/1.1/>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)
Prefix(dcterms:=<http://purl.org/dc/terms/>)


Ontology(<http://purl.obolibrary.org/obo/dxto.owl>
Import(<http://purl.obolibrary.org/obo/dxto/components/dxto-diagnostic-relations.owl>)
Import(<http://purl.obolibrary.org/obo/dxto/components/dxto-mappings.owl>)
Import(<http://purl.obolibrary.org/obo/dxto/imports/mondo_import.owl>)
Annotation(dcterms:description "None")
Annotation(dcterms:license <https://creativecommons.org/licenses/unspecified>)
Annotation(dcterms:title "Diagnostic Test Ontology")

Declaration(Class(<http://purl.obolibrary.org/obo/DXTO_0000000>))
Declaration(AnnotationProperty(dcterms:description))
Declaration(AnnotationProperty(dcterms:license))
Declaration(AnnotationProperty(dcterms:title))
############################
#   Annotation Properties
############################

# Annotation Property: dcterms:description (description)

AnnotationAssertion(rdfs:label dcterms:description "description")

# Annotation Property: dcterms:license (license)

AnnotationAssertion(rdfs:label dcterms:license "license")

# Annotation Property: dcterms:title (title)

AnnotationAssertion(rdfs:label dcterms:title "title")



############################
#   Object Properties
############################

Declaration(ObjectProperty(<http://purl.obolibrary.org/obo/dxto/is_diagnostic_for>))
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/dxto/is_diagnostic_for> "is diagnostic for"@en)

############################
#   Annotation Properties
############################

Declaration(AnnotationProperty(<http://purl.obolibrary.org/obo/IAO_0000115>))
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/IAO_0000115> "definition")

Declaration(AnnotationProperty(<http://purl.obolibrary.org/obo/dxto/diagnostic_role>))
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/dxto/diagnostic_role> "diagnostic role"@en)

Declaration(AnnotationProperty(<http://purl.obolibrary.org/obo/dxto/diagnostic_tier>))
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/dxto/diagnostic_tier> "diagnostic tier"@en)

Declaration(AnnotationProperty(<http://purl.obolibrary.org/obo/dxto/diagnostic_evidence>))
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/dxto/diagnostic_evidence> "diagnostic evidence"@en)

Declaration(AnnotationProperty(<http://purl.org/dc/terms/source>))

############################
#   Classes
############################

# Class: <http://purl.obolibrary.org/obo/DXTO_0000000> (root node)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/DXTO_0000000> "root node"@en)

# Class: <http://purl.obolibrary.org/obo/DXTO_0000001> (sweat chloride test)

Declaration(Class(<http://purl.obolibrary.org/obo/DXTO_0000001>))
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/DXTO_0000001> "sweat chloride test"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/DXTO_0000001> "A quantitative measurement of chloride concentration in sweat collected by pilocarpine iontophoresis, used to diagnose cystic fibrosis."@en)
SubClassOf(<http://purl.obolibrary.org/obo/DXTO_0000001> <http://purl.obolibrary.org/obo/DXTO_0000000>)

# Class: <http://purl.obolibrary.org/obo/DXTO_0000002> (CFTR gene targeted mutation analysis)

Declaration(Class(<http://purl.obolibrary.org/obo/DXTO_0000002>))
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/DXTO_0000002> "CFTR gene targeted mutation analysis"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/DXTO_0000002> "A molecular genetic test that detects specific pathogenic variants in the CFTR gene in blood or tissue, used to confirm a diagnosis of cystic fibrosis."@en)
SubClassOf(<http://purl.obolibrary.org/obo/DXTO_0000002> <http://purl.obolibrary.org/obo/DXTO_0000000>)


)